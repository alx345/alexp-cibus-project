<mxfile host="app.diagrams.net">
  <diagram name="HelloCibus GitOps Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="dev" value="Developer&#10;(Git Push)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="git" value="Git Repository&#10;(App + K8s + Terraform)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="argocd" value="ArgoCD&#10;(GitOps Controller)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="cluster" value="Minikube Cluster" style="swimlane;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="250" width="500" height="300" as="geometry"/>
        </mxCell>

        <mxCell id="ingress" value="Ingress&#10;(HTTPS + TLS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="cluster">
          <mxGeometry x="150" y="20" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="service" value="Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="cluster">
          <mxGeometry x="150" y="110" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="pod" value="Pod&#10;Python REST API&#10;(Docker, non-root)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="cluster">
          <mxGeometry x="150" y="200" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="user" value="End User&#10;(Browser / curl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="800" y="300" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="dev" target="git">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="git" target="argocd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="Sync" edge="1" parent="1" source="argocd" target="cluster">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="cluster" source="ingress" target="service">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="cluster" source="service" target="pod">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="HTTPS" edge="1" parent="1" source="user" target="ingress">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
